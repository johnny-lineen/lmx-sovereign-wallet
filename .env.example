# Copy to `.env.local` (or `.env`) in the repo root. Restart `npm run dev` after changes.
# The variable name must be exactly DATABASE_URL (all caps). Plain `npx prisma` only loads `.env`; use `npm run db:push` / `db:pull` / `db:studio` / `db:migrate` to load `.env.local` then `.env`, or duplicate DATABASE_URL into `.env`.
# Use one pair of quotes around the whole URL only—never `".../mydb""` or a `"` inside the path (that becomes %22 and breaks the DB name).
#
# PostgreSQL (Railway, Supabase, Neon, local Postgres, etc.)
# Replace USER, PASSWORD, YOUR_POSTGRES_HOST, and YOUR_DATABASE_NAME with real values (Neon/Supabase/Railway copy a ready-made URL).
DATABASE_URL="postgresql://USER:PASSWORD@YOUR_POSTGRES_HOST:5432/YOUR_DATABASE_NAME?schema=public"

# Clerk — https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""

# Prisma seed (`npm run db:seed`): Clerk user id for the account you sign in with locally.
# Dashboard → Users → your user → User ID (same value as auth().userId in the app).
SEED_CLERK_USER_ID=""

# Move seeded vault rows onto your session user (`npm run db:align-vault`) if seed used a different clerkUserId.
# Use the Clerk User ID shown on the Vault empty state (must match auth().userId).
VAULT_OWNER_CLERK_USER_ID=""
# Optional: source clerkUserId from `npm run db:peek` (e.g. user_dev_lmx_owner). If omitted, picks the user with the most vault items.
VAULT_MOVE_FROM_CLERK_USER_ID=""

# Optional: explicit auth URLs (defaults work if paths match these)
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/dashboard"

# Gmail import (Google Cloud OAuth client — Web application). Authorized redirect URI must match exactly, e.g. http://localhost:3000/api/import/gmail/callback
GOOGLE_GMAIL_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_GMAIL_CLIENT_SECRET="your-google-client-secret"
GOOGLE_GMAIL_REDIRECT_URI="http://localhost:3000/api/import/gmail/callback"
# Used for post-OAuth redirects when not same-origin (production app URL, no trailing slash)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Required if Gmail import is enabled. Must be at least 32 chars.
LMX_TOKEN_ENCRYPTION_KEY="replace-with-a-long-random-secret"

# Optional: webhook for production error alerts (Slack/Discord/custom)
OPS_ALERT_WEBHOOK_URL=""

# Optional: comma-separated Clerk user IDs for controlled test-user rollout.
TEST_USER_ALLOWLIST=""
